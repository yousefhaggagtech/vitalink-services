NODE_ENV=development
PORT=4000
SERVICE_NAME=vitalink-services

# Database
DB_SERVER=your-database-server.com
DB_PORT=1433
DB_NAME=VitaLinkDb
DB_USER=your_username
DB_PASSWORD=your_password
DB_ENCRYPT=false

# Auth
JWT_SECRET=your-shared-secret-from-net-backend-min-32-chars-long
JWT_AUDIENCE=VitaLinkClient
JWT_ISSUER=https://vitalink-api.azurewebsites.net

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# AI Service
AI_CACHE_TTL_SECONDS=3
AI_STALE_THRESHOLD_SECONDS=30
AI_WARMUP_DURATION_SECONDS=120
